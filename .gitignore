# Experiment results (scan sweeps, checkpoints, logs)
results/**/*.json
results/**/*.jsonl
results/**/*.log
results/**/checkpoint_last.pt

# Packaging artifacts
**/*.tar.gz
**/*.tgz

# Secrets and local credentials
.env
.env.*
secrets/
.secrets/
*.pw
*.pw.txt

