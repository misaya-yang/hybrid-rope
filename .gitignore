# Python cache
**/__pycache__/
**/*.pyc

# Runtime / temp markers
**/*.pid
exp_pid.txt
experiment_log.txt
full_experiment.log
outputs/
logs/
.tmp_sync/

# Large model / checkpoint binaries
**/*.safetensors
**/*.pt
**/*.pth
**/*.bin
**/*.ckpt
**/*.h5
**/*.onnx
**/optimizer.*
**/scheduler.*
