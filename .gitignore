# LaTeX build artifacts (paper/main.pdf at paper root IS committed)
paper/build/

# Python cache
**/__pycache__/
**/*.pyc

# Runtime / temp markers
**/*.pid
exp_pid.txt
experiment_log.txt
full_experiment.log
outputs/
logs/
.tmp_sync/

# Large model / checkpoint binaries
**/*.safetensors
**/*.pt
**/*.pth
**/*.bin
**/*.ckpt
**/*.h5
**/*.onnx
**/optimizer.*
**/scheduler.*
**/rng_state.*
**/training_args.*
**/cache/*

# Experiment results — entire folder ignored
# Results are synced between machines via rsync, not git
# To sync: rsync -avz --exclude='*.pt' --exclude='*.npy' results/ <remote>:results/
results/

# Packaging artifacts
**/*.tar.gz
**/*.tgz

# Secrets and local credentials
.env
.env.*
secrets/
.secrets/
*.pw
*.pw.txt

# Paper LaTeX build artifacts
paper/*.aux
paper/*.bbl
paper/*.blg
paper/*.fdb_latexmk
paper/*.fls
paper/*.log
paper/*.out
paper/*.synctex.gz
paper/*.toc
paper/*.pdf
paper/*.dvi
paper/*.nav
paper/*.snm
paper/*.vrb
paper/*.brf

# Internal tool/review artifacts (not for public repo)
internal/tools/
internal/reviews/
internal/local_snapshots/

# Brief build artifacts
internal/brief/*.aux
internal/brief/*.log
internal/brief/*.out

# Local environments
.venv/
venv/

# Local video experiment caches
data/video_temporal/generated/
data/video_temporal/external/

# Skill / assistant definition files
*.skill
**/*.skill

# Tooling metadata
.codex/
.codex_tmp/
.claude/

# macOS metadata
.DS_Store
**/.DS_Store
