    "7A_yarn_verification": {
      "purpose": "Verify YaRN implementation correctness and hyperparameter ablation",
      "ablation": {
        "Y1_default": {"beta_fast": 32, "beta_slow": 1, "ppl_128": 329.724, "ppl_8k": 407.591},
