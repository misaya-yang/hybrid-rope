\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces 750M training dynamics (1B tokens, FineWeb-Edu + 3\% passkey, seed=42). Both methods exhibit comparable OOD PPL degradation (waterbed), but their passkey trajectories \emph  {diverge}: Geometric regresses from 70\%$\to $60\% after 50\%, while Hybrid monotonically improves to 80\%. AR exact match nearly doubles (30\% vs.\ 16.3\%).}}{8}{table.6}\protected@file@percent }
\newlabel{tab:750m_dynamics}{{6}{8}{750M training dynamics (1B tokens, FineWeb-Edu + 3\% passkey, seed=42). Both methods exhibit comparable OOD PPL degradation (waterbed), but their passkey trajectories \emph {diverge}: Geometric regresses from 70\%$\to $60\% after 50\%, while Hybrid monotonically improves to 80\%. AR exact match nearly doubles (30\% vs.\ 16.3\%)}{table.6}{}}
