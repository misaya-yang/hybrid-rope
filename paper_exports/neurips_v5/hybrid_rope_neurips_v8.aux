\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces From-scratch EVQ vs.\ Geometric across scales and datasets. Short-context cost $\le +0.4\%$; long-context improvement 10--19\% at 50M--350M. The 750M Hybrid ($\tau {=}1.5$, $r{=}16$ partial warp) shows slightly worse OOD PPL than Geometric, but this is compensated by dramatically better positional retrieval (Table\nobreakspace  {}\ref  {tab:750m_dynamics}). Note: 750M uses Hybrid (partial warp) while 50M--350M use full EVQ (all channels warped).}}{6}{table.2}\protected@file@percent }
\newlabel{tab:scaling}{{2}{6}{From-scratch EVQ vs.\ Geometric across scales and datasets. Short-context cost $\le +0.4\%$; long-context improvement 10--19\% at 50M--350M. The 750M Hybrid ($\tau {=}1.5$, $r{=}16$ partial warp) shows slightly worse OOD PPL than Geometric, but this is compensated by dramatically better positional retrieval (Table~\ref {tab:750m_dynamics}). Note: 750M uses Hybrid (partial warp) while 50M--350M use full EVQ (all channels warped)}{table.2}{}}
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces 350M FineWeb-Edu 3-seed detail (50M tokens, base=500K). Improvement grows monotonically with evaluation length, consistent with the waterbed prediction.}}{6}{table.3}\protected@file@percent }
