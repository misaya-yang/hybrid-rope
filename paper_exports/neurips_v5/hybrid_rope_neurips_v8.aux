\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {EVQ frequency allocation and training dynamics at 750M scale.} (a)\nobreakspace  {}Log-frequency allocation: EVQ ($\tau {=}1.5$) expands low-frequency spacing and compresses high-frequency spacing relative to Geometric. (b)\nobreakspace  {}OOD perplexity at L=8K: both methods exhibit comparable waterbed degradation during training, with in-distribution PPL (L=2K, dashed) closely matched. (c)\nobreakspace  {}Passkey retrieval at L=8K: Geometric regresses after 50\% training ($-$10pp), while Hybrid monotonically improves (+10pp over the same period), reaching a final +20pp gap. This \emph  {retrieval divergence} despite symmetric PPL waterbed is the central empirical finding.}}{9}{figure.1}\protected@file@percent }
\newlabel{fig:main}{{1}{9}{\textbf {EVQ frequency allocation and training dynamics at 750M scale.} (a)~Log-frequency allocation: EVQ ($\tau {=}1.5$) expands low-frequency spacing and compresses high-frequency spacing relative to Geometric. (b)~OOD perplexity at L=8K: both methods exhibit comparable waterbed degradation during training, with in-distribution PPL (L=2K, dashed) closely matched. (c)~Passkey retrieval at L=8K: Geometric regresses after 50\% training ($-$10pp), while Hybrid monotonically improves (+10pp over the same period), reaching a final +20pp gap. This \emph {retrieval divergence} despite symmetric PPL waterbed is the central empirical finding}{figure.1}{}}
\@writefile{lot}{\contentsline {table}{\numberline {8}{\ignorespaces Base=10K, 350M, 50M tokens, $L=4096$. EVQ fails on all metrics, confirming the collision-block dead-zone prediction. This negative result validates the theory from the opposite direction.}}{9}{table.8}\protected@file@percent }
\newlabel{tab:collision_10k}{{8}{9}{Base=10K, 350M, 50M tokens, $L=4096$. EVQ fails on all metrics, confirming the collision-block dead-zone prediction. This negative result validates the theory from the opposite direction}{table.8}{}}
